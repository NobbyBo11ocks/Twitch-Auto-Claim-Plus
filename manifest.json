{
  "manifest_version": 3,
  "name": "Twitch Auto Claim Plus",
  "version": "1.1.1",
  "description": "Created By NobbyBollocks. Twitch Auto Claim Plus.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://twitch.tv/*",
    "*://*.twitch.tv/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "*://twitch.tv/*",
        "*://*.twitch.tv/*"
      ],
      "js": [
        "theme-presets.js",
        "declutter-options.js",
        "settings-schema.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Twitch Auto Claim Plus",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/icon32.png"
      ],
      "matches": [
        "*://twitch.tv/*",
        "*://*.twitch.tv/*"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "twitch-tools@addons.nobbybollocks",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}