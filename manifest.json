{
  "manifest_version": 3,
  "name": "Twitch Auto Claim Plus",
  "version": "1.6.9",
  "description": "Created By NobbyBollocks. Twitch Auto Claim Plus.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "*://twitch.tv/*",
    "*://*.twitch.tv/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://twitch.tv/*",
        "*://*.twitch.tv/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Twitch Auto Claim Plus",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "twitch-tools@addons.nobbybollocks",
      "strict_min_version": "142.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
